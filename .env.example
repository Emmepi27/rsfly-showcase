# ============================================================
#  RSFly — example environment configuration
#  PLACEHOLDERS ONLY. Copy to .env and set your own LOCAL values.
#  Never commit a real .env (it is git-ignored).
# ============================================================

# ---- Django ----
DJANGO_SECRET_KEY=change-me-generate-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ---- Database (PostgreSQL + PostGIS) ----
DATABASE_URL=postgis://USER:PASSWORD@localhost:5432/rsfly
POSTGRES_DB=rsfly
POSTGRES_USER=rsfly
POSTGRES_PASSWORD=change-me

# ---- Cache / task queue ----
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0

# ---- Frontend (Nuxt) ----
NUXT_PUBLIC_API_BASE=http://localhost:8000

# ---- Map tiles (bring your own provider key) ----
MAP_TILES_API_KEY=your-map-tiles-key

# ---- Object storage (optional, for media) ----
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
